{
  "info": {
    "name": "LostFound Connect API",
    "description": "Koleksi Endpoint API untuk sistem Lost and Found Connect (Backend Laravel). Siap di-import ke aplikasi Bruno / Postman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication & Profile",
      "item": [
        {
          "name": "1.1 Register Mahasiswa",
          "request": {
            "method": "POST",
            "header": [{"key": "Accept", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama_lengkap\": \"Ahmad Dahlan\",\n  \"email\": \"ahmad@student.unper.ac.id\",\n  \"password\": \"password123\",\n  \"no_hp\": \"08123456789\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "register"] }
          }
        },
        {
          "name": "1.2 Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Accept", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ahmad@student.unper.ac.id\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login"] }
          }
        },
        {
          "name": "1.3 Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": { "raw": "{{base_url}}/api/v1/auth/profile", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "profile"] }
          }
        },
        {
          "name": "1.4 Get User Riwayat Activity",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": { "raw": "{{base_url}}/api/v1/auth/riwayat", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "riwayat"] }
          }
        },
        {
          "name": "1.5 Get Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": { "raw": "{{base_url}}/api/v1/auth/stats", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "stats"] }
          }
        },
        {
          "name": "1.6 Logout",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": { "raw": "{{base_url}}/api/v1/auth/logout", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "2. Items (Mading & Antrean)",
      "item": [
        {
          "name": "2.1 Lihat Papan Mading (Fuzzy Search)",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": { "raw": "{{base_url}}/api/v1/items?post_type=lost&q=Kunci Motor Honda", "host": ["{{base_url}}"], "path": ["api", "v1", "items"], "query": [
              {"key": "post_type", "value": "lost"},
              {"key": "q", "value": "Kunci Motor Honda"}
            ]}
          }
        },
        {
          "name": "2.2 Buat Laporan Barang (Lost/Found)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "judul", "value": "Dompet Coklat", "type": "text"},
                {"key": "deskripsi", "value": "Ditemukan dompet kulit coklat.", "type": "text"},
                {"key": "deskripsi_rahasia", "value": "Ada KTP atas nama Budi.", "type": "text"},
                {"key": "post_type", "value": "found", "type": "text"},
                {"key": "tanggal_lapor", "value": "2026-06-20 10:00:00", "type": "text"},
                {"key": "category_id", "value": "2", "type": "text"},
                {"key": "location_id", "value": "4", "type": "text"}
              ]
            },
            "url": { "raw": "{{base_url}}/api/v1/items", "host": ["{{base_url}}"], "path": ["api", "v1", "items"] }
          }
        },
        {
          "name": "2.3 Lihat Antrean Barang (Khusus Satpam)",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": { "raw": "{{base_url}}/api/v1/admin/items?visibility=private", "host": ["{{base_url}}"], "path": ["api", "v1", "admin", "items"], "query": [
              {"key": "visibility", "value": "private"}
            ] }
          }
        },
        {
          "name": "2.4 Terima & Rilis Barang (Khusus Satpam)",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": { "raw": "{{base_url}}/api/v1/items/1/release", "host": ["{{base_url}}"], "path": ["api", "v1", "items", "1", "release"] }
          }
        },
        {
          "name": "2.5 Tolak/Batalkan Barang (Khusus Satpam)",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": { "raw": "{{base_url}}/api/v1/items/1/reject", "host": ["{{base_url}}"], "path": ["api", "v1", "items", "1", "reject"] }
          }
        }
      ]
    },
    {
      "name": "3. Claims Processing",
      "item": [
        {
          "name": "3.1 Ajukan Klaim",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "item_id", "value": "1", "type": "text"},
                {"key": "bukti_teks", "value": "Itu dompet saya, isinya uang dan KTP saya", "type": "text"},
                {"key": "foto_ktp", "type": "file"},
                {"key": "foto_bukti_pendukung", "type": "file"}
              ]
            },
            "url": { "raw": "{{base_url}}/api/v1/claims", "host": ["{{base_url}}"], "path": ["api", "v1", "claims"] }
          }
        },
        {
          "name": "3.2 Daftar Semua Klaim (Satpam)",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": { "raw": "{{base_url}}/api/v1/claims", "host": ["{{base_url}}"], "path": ["api", "v1", "claims"] }
          }
        },
        {
          "name": "3.3 Verifikasi Klaim (Satpam)",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status_verif\": \"approved\",\n  \"catatan\": \"KTP sesuai dengan barang\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/v1/claims/1/verify", "host": ["{{base_url}}"], "path": ["api", "v1", "claims", "1", "verify"] }
          }
        },
        {
          "name": "3.4 Cari Klaim via Token (Satpam)",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": { "raw": "{{base_url}}/api/v1/claims/token/LF-ORANGE-XXXXXX", "host": ["{{base_url}}"], "path": ["api", "v1", "claims", "token", "LF-ORANGE-XXXXXX"] }
          }
        }
      ]
    },
    {
      "name": "4. Handover & Archiving",
      "item": [
        {
          "name": "4.1 Eksekusi Serah Terima (Satpam)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "claim_id", "value": "1", "type": "text"},
                {"key": "foto_serah_terima", "type": "file"}
              ]
            },
            "url": { "raw": "{{base_url}}/api/v1/handovers", "host": ["{{base_url}}"], "path": ["api", "v1", "handovers"] }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "token",
      "value": "PASTE_TOKEN_LOGIN_DI_SINI"
    }
  ]
}
